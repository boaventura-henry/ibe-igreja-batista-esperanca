generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  LEADER
  TREASURER
}

enum DashboardWidgetCategory {
  MEMBERS
  MINISTRIES
  EVENTS
  SCALES
  FINANCE
  CONTRIBUTIONS
  ANNOUNCEMENTS
  NOTIFICATIONS
  SYSTEM
}

enum DashboardWidgetSensitivity {
  PUBLIC
  INTERNAL
  RESTRICTED
}

enum DashboardWidgetPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum DashboardWidgetSize {
  SMALL
  MEDIUM
  LARGE
  FULL
}

enum DashboardWidgetIconKey {
  USERS
  CAKE
  CALENDAR
  MUSIC
  WALLET
  TRENDING_UP
  HAND_COINS
  MEGAPHONE
  BELL
  HEART_PULSE
  SERVER
  SHIELD
}

enum DashboardWidgetVisualVariant {
  DEFAULT
  INFO
  POSITIVE
  WARNING
  DANGER
  RESTRICTED
}

enum DashboardLayoutMode {
  COMPACT
  BALANCED
  EXPANDED
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  VISITOR
  TRANSFERRED
  DECEASED
}

enum DonationType {
  TITHE
  OFFERING
  CAMPAIGN
}

enum MemberSex {
  FEMALE
  MALE
  OTHER
  NOT_INFORMED
}

enum WeekDay {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum MinistryIcon {
  MUSIC
  CHILDREN
  CAMERA
  USERS
  HEART
  CROSS
  BOOK
  CHURCH
  MIC
  HOME
}

enum MemberMinistryRole {
  LEADER
  VICE_LEADER
  SECRETARY
  TREASURER
  VOLUNTEER
  MEMBER
}

enum MemberMinistryStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  REMOVED
  LEFT
}

enum ScheduleStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELED
}

enum ScheduleMemberStatus {
  PENDING
  CONFIRMED
  DECLINED
  REPLACED
  ABSENT
}

enum ScheduleMemberRole {
  LEADER
  VOCAL
  INSTRUMENT
  MEDIA
  RECEPTION
  CHILDREN
  SUPPORT
  OTHER
}

enum EventType {
  SERVICE
  CONFERENCE
  MEETING
  CLASS
  COURSE
  REHEARSAL
  VIGIL
  RETREAT
  OUTREACH
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELED
  COMPLETED
}

enum FinancialEntryType {
  INCOME
  EXPENSE
}

enum FinancialPaymentMethod {
  CASH
  PIX
  DEBIT_CARD
  CREDIT_CARD
  BANK_TRANSFER
  CHECK
  OTHER
}

enum FinancialEntryStatus {
  PENDING
  CONFIRMED
  CANCELED
  REFUNDED
}

enum FinancialEntryOrigin {
  MANUAL
  PIX
  EVENT
  OTHER
}

enum UserAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum PasswordResetRequestStatus {
  PENDING
  COMPLETED
  REJECTED
  CANCELED
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AnnouncementAudience {
  ALL
  MINISTRY
  PORTAL_ONLY
}

enum PushNotificationTargetType {
  USER
  ROLE
  ALL
  DEVICE
  RETRY_FAILED
}

enum PushNotificationLogStatus {
  PENDING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
}

enum PushNotificationLogDeviceStatus {
  SUCCESS
  FAILED
  EXPIRED
  REMOVED
  SKIPPED
}

enum PushNotificationSkipReason {
  ALREADY_SUCCEEDED_IN_LATER_ATTEMPT
  SUBSCRIPTION_NOT_FOUND
  SUBSCRIPTION_INACTIVE
  DEVICE_ALREADY_REMOVED
  ENDPOINT_HASH_CHANGED
  USER_INACTIVE
  DEVICE_OWNER_CHANGED
  NO_LONGER_ELIGIBLE
  UNKNOWN
}

model User {
  id                             String                      @id @default(cuid())
  name                           String
  username                       String                      @unique
  email                          String                      @unique
  passwordHash                   String
  role                           UserRole                    @default(LEADER)
  memberId                       String?                     @unique
  accessRoleId                   String?
  isActive                       Boolean                     @default(true)
  mustChangePassword             Boolean                     @default(false)
  lastLoginAt                    DateTime?
  failedLoginAttempts            Int                         @default(0)
  lockedUntil                    DateTime?
  lastSeenAppVersion             String?
  member                         Member?                     @relation("MemberUser", fields: [memberId], references: [id], onDelete: SetNull)
  accessRole                     AccessRole?                 @relation("UserAccessRole", fields: [accessRoleId], references: [id], onDelete: SetNull)
  createdMembers                 Member[]                    @relation("MemberCreatedBy")
  updatedMembers                 Member[]                    @relation("MemberUpdatedBy")
  createdMemberMinistries        MemberMinistry[]            @relation("MemberMinistryCreatedBy")
  updatedMemberMinistries        MemberMinistry[]            @relation("MemberMinistryUpdatedBy")
  createdSchedules               Schedule[]                  @relation("ScheduleCreatedBy")
  updatedSchedules               Schedule[]                  @relation("ScheduleUpdatedBy")
  createdSongs                   Song[]                      @relation("SongCreatedBy")
  updatedSongs                   Song[]                      @relation("SongUpdatedBy")
  createdScheduleSongs           ScheduleSong[]              @relation("ScheduleSongCreatedBy")
  updatedScheduleSongs           ScheduleSong[]              @relation("ScheduleSongUpdatedBy")
  createdScheduleMembers         ScheduleMember[]            @relation("ScheduleMemberCreatedBy")
  updatedScheduleMembers         ScheduleMember[]            @relation("ScheduleMemberUpdatedBy")
  createdEvents                  Event[]                     @relation("EventCreatedBy")
  updatedEvents                  Event[]                     @relation("EventUpdatedBy")
  createdFinancialCategories     FinancialCategory[]         @relation("FinancialCategoryCreatedBy")
  updatedFinancialCategories     FinancialCategory[]         @relation("FinancialCategoryUpdatedBy")
  createdFinancialEntries        FinancialEntry[]            @relation("FinancialEntryCreatedBy")
  updatedFinancialEntries        FinancialEntry[]            @relation("FinancialEntryUpdatedBy")
  openedFinancialClosings        FinancialClosing[]          @relation("FinancialClosingOpenedBy")
  closedFinancialClosings        FinancialClosing[]          @relation("FinancialClosingClosedBy")
  createdAnnouncements           Announcement[]              @relation("AnnouncementCreatedBy")
  updatedAnnouncements           Announcement[]              @relation("AnnouncementUpdatedBy")
  announcementReads              AnnouncementRead[]
  approvedAccessRequests         UserAccessRequest[]         @relation("UserAccessRequestApprovedBy")
  rejectedAccessRequests         UserAccessRequest[]         @relation("UserAccessRequestRejectedBy")
  passwordResetRequests          PasswordResetRequest[]      @relation("PasswordResetRequestUser")
  processedPasswordResetRequests PasswordResetRequest[]      @relation("PasswordResetRequestProcessedBy")
  pushSubscriptions              PushSubscription[]
  notificationPreference         NotificationPreference?
  createdPushNotificationLogs    PushNotificationLog[]       @relation("PushNotificationLogCreatedBy")
  retriedPushNotificationLogs    PushNotificationLog[]       @relation("PushNotificationLogRetriedBy")
  pushNotificationLogDevices     PushNotificationLogDevice[] @relation("PushNotificationLogDeviceUser")
  createdMinistries              Ministry[]                  @relation("MinistryCreatedBy")
  updatedMinistries              Ministry[]                  @relation("MinistryUpdatedBy")
  createdAccessRoles             AccessRole[]                @relation("AccessRoleCreatedBy")
  updatedAccessRoles             AccessRole[]                @relation("AccessRoleUpdatedBy")
  createdAt                      DateTime                    @default(now())
  updatedAt                      DateTime                    @updatedAt

  @@index([accessRoleId])
}

model PushSubscription {
  id               String    @id @default(cuid())
  userId           String
  endpoint         String    @unique
  p256dh           String
  auth             String
  expirationTime   DateTime?
  deviceName       String?
  userAgent        String?
  isActive         Boolean   @default(true)
  lastUsedAt       DateTime?
  lastSuccessAt    DateTime?
  lastFailureAt    DateTime?
  failureCount     Int       @default(0)
  testSentAt       DateTime?
  testConfirmedAt  DateTime?
  testFailedAt     DateTime?
  setupCompletedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  revokedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
  @@index([isActive])
  @@index([revokedAt])
}

model NotificationPreference {
  id          String   @id @default(cuid())
  userId      String   @unique
  pushEnabled Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushNotificationLog {
  id                  String                      @id @default(cuid())
  createdAt           DateTime                    @default(now())
  createdById         String?
  originalLogId       String?
  retrySourceLogId    String?
  retryNumber         Int                         @default(0)
  retriedById         String?
  title               String
  body                String
  targetType          PushNotificationTargetType
  targetDescription   String?
  devicesFound        Int                         @default(0)
  devicesAttempted    Int                         @default(0)
  devicesSucceeded    Int                         @default(0)
  devicesFailed       Int                         @default(0)
  devicesSkipped      Int                         @default(0)
  status              PushNotificationLogStatus   @default(PENDING)
  startedAt           DateTime?
  finishedAt          DateTime?
  durationMs          Int?
  errorMessage        String?
  retryLockKey        String?                     @unique
  idempotencyKey      String?                     @unique
  payloadJson         Json?
  createdBy           User?                       @relation("PushNotificationLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  retriedBy           User?                       @relation("PushNotificationLogRetriedBy", fields: [retriedById], references: [id], onDelete: SetNull)
  originalLog         PushNotificationLog?        @relation("PushNotificationOriginalLog", fields: [originalLogId], references: [id], onDelete: SetNull)
  retryAttempts       PushNotificationLog[]       @relation("PushNotificationOriginalLog")
  retrySourceLog      PushNotificationLog?        @relation("PushNotificationRetrySourceLog", fields: [retrySourceLogId], references: [id], onDelete: SetNull)
  retrySourceAttempts PushNotificationLog[]       @relation("PushNotificationRetrySourceLog")
  devices             PushNotificationLogDevice[]

  @@unique([originalLogId, retryNumber])
  @@index([createdAt])
  @@index([createdById])
  @@index([originalLogId])
  @@index([retrySourceLogId])
  @@index([retryNumber])
  @@index([retriedById])
  @@index([targetType])
  @@index([status])
  @@index([startedAt])
  @@index([finishedAt])
}

model PushNotificationLogDevice {
  id                String                          @id @default(cuid())
  logId             String
  deviceId          String?
  userId            String?
  memberId          String?
  sourceLogDeviceId String?
  attemptNumber     Int                             @default(0)
  deviceName        String?
  platform          String?
  browser           String?
  endpointHash      String
  status            PushNotificationLogDeviceStatus
  skipReason        PushNotificationSkipReason?
  httpStatus        Int?
  pushService       String?
  errorCode         String?
  errorMessage      String?
  sentAt            DateTime?
  lastCheckedAt     DateTime?
  log               PushNotificationLog             @relation(fields: [logId], references: [id], onDelete: Cascade)
  sourceLogDevice   PushNotificationLogDevice?      @relation("PushNotificationLogDeviceRetrySource", fields: [sourceLogDeviceId], references: [id], onDelete: SetNull)
  retryDevices      PushNotificationLogDevice[]     @relation("PushNotificationLogDeviceRetrySource")
  user              User?                           @relation("PushNotificationLogDeviceUser", fields: [userId], references: [id], onDelete: SetNull)
  member            Member?                         @relation("PushNotificationLogDeviceMember", fields: [memberId], references: [id], onDelete: SetNull)

  @@index([logId])
  @@index([deviceId])
  @@index([userId])
  @@index([memberId])
  @@index([sourceLogDeviceId])
  @@index([endpointHash])
  @@index([status])
  @@index([sentAt])
}

model AccessRole {
  id               String                      @id @default(cuid())
  name             String                      @unique
  description      String?
  permissions      Permission[]                @relation("AccessRolePermissions")
  isSystem         Boolean                     @default(false)
  isActive         Boolean                     @default(true)
  deletedAt        DateTime?
  createdById      String?
  updatedById      String?
  createdBy        User?                       @relation("AccessRoleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        User?                       @relation("AccessRoleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  users            User[]                      @relation("UserAccessRole")
  dashboardWidgets AccessRoleDashboardWidget[]
  dashboardLayout  AccessRoleDashboardLayout?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@index([name])
  @@index([isActive])
  @@index([deletedAt])
}

model Permission {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  label            String
  description      String?
  module           String
  isSystem         Boolean           @default(true)
  isActive         Boolean           @default(true)
  accessRoles      AccessRole[]      @relation("AccessRolePermissions")
  dashboardWidgets DashboardWidget[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([code])
  @@index([module])
  @@index([isActive])
}

model DashboardWidget {
  id                      String                       @id @default(cuid())
  code                    String                       @unique
  title                   String
  description             String?
  category                DashboardWidgetCategory
  sensitivity             DashboardWidgetSensitivity   @default(INTERNAL)
  priority                DashboardWidgetPriority      @default(NORMAL)
  defaultSize             DashboardWidgetSize          @default(MEDIUM)
  defaultVisibleOnMobile  Boolean                      @default(true)
  defaultVisibleOnTablet  Boolean                      @default(true)
  defaultVisibleOnDesktop Boolean                      @default(true)
  iconKey                 DashboardWidgetIconKey       @default(SERVER)
  visualVariant           DashboardWidgetVisualVariant @default(DEFAULT)
  permissionId            String
  permission              Permission                   @relation(fields: [permissionId], references: [id], onDelete: Restrict)
  defaultOrder            Int
  isEnabled               Boolean                      @default(true)
  isSystem                Boolean                      @default(true)
  accessRoles             AccessRoleDashboardWidget[]
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt

  @@index([permissionId])
  @@index([category, defaultOrder])
  @@index([isEnabled])
}

model AccessRoleDashboardWidget {
  id                String               @id @default(cuid())
  accessRoleId      String
  dashboardWidgetId String
  isVisible         Boolean              @default(true)
  sortOrder         Int?
  size              DashboardWidgetSize?
  visibleOnMobile   Boolean?
  visibleOnTablet   Boolean?
  visibleOnDesktop  Boolean?
  accessRole        AccessRole           @relation(fields: [accessRoleId], references: [id], onDelete: Cascade)
  dashboardWidget   DashboardWidget      @relation(fields: [dashboardWidgetId], references: [id], onDelete: Cascade)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([accessRoleId, dashboardWidgetId])
  @@index([accessRoleId, isVisible])
  @@index([dashboardWidgetId])
}

model AccessRoleDashboardLayout {
  id                    String              @id @default(cuid())
  accessRoleId          String              @unique
  layoutMode            DashboardLayoutMode @default(BALANCED)
  desktopColumns        Int                 @default(3)
  tabletColumns         Int                 @default(2)
  mobileColumns         Int                 @default(1)
  showCategoryHeaders   Boolean             @default(true)
  allowCategoryCollapse Boolean             @default(true)
  accessRole            AccessRole          @relation(fields: [accessRoleId], references: [id], onDelete: Cascade)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([accessRoleId])
}

model Member {
  id                         String                      @id @default(cuid())
  name                       String
  nickname                   String?
  cpf                        String?                     @unique
  rg                         String?
  birthDate                  DateTime?
  sex                        MemberSex                   @default(NOT_INFORMED)
  maritalStatus              String?
  phone                      String?
  mobilePhone                String?
  whatsapp                   String?
  email                      String?                     @unique
  zipCode                    String?
  street                     String?
  number                     String?
  complement                 String?
  district                   String?
  city                       String?
  state                      String?
  baptismDate                DateTime?
  joinedAt                   DateTime?
  status                     MemberStatus                @default(ACTIVE)
  notes                      String?
  photoUrl                   String?
  deletedAt                  DateTime?
  createdById                String?
  updatedById                String?
  user                       User?                       @relation("MemberUser")
  createdBy                  User?                       @relation("MemberCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy                  User?                       @relation("MemberUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  ledMinistries              Ministry[]                  @relation("MinistryLeader")
  viceLedMinistries          Ministry[]                  @relation("MinistryViceLeader")
  donations                  Donation[]
  financialEntries           FinancialEntry[]
  memberMinistries           MemberMinistry[]
  pushNotificationLogDevices PushNotificationLogDevice[] @relation("PushNotificationLogDeviceMember")
  scheduleMembers            ScheduleMember[]            @relation("ScheduleMemberMember")
  replacements               ScheduleMember[]            @relation("ScheduleMemberReplacement")
  leadScheduleSongs          ScheduleSong[]              @relation("ScheduleSongLeadMember")
  responsibleEvents          Event[]                     @relation("EventResponsibleMember")
  possibleAccessRequests     UserAccessRequest[]         @relation("UserAccessRequestPossibleMember")
  approvedAccessRequests     UserAccessRequest[]         @relation("UserAccessRequestApprovedMember")
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  @@index([name])
  @@index([cpf])
  @@index([city])
  @@index([status])
  @@index([deletedAt])
}

model Ministry {
  id                 String           @id @default(cuid())
  name               String           @unique
  slug               String           @unique
  description        String?
  color              String           @default("#2563eb")
  icon               MinistryIcon     @default(USERS)
  imageUrl           String?
  displayOrder       Int              @default(0)
  email              String?
  phone              String?
  meetingDay         WeekDay?
  meetingTime        String?
  location           String?
  notes              String?
  isActive           Boolean          @default(true)
  isSystem           Boolean          @default(false)
  leaderMemberId     String?
  viceLeaderMemberId String?
  createdById        String?
  updatedById        String?
  deletedAt          DateTime?
  leaderMember       Member?          @relation("MinistryLeader", fields: [leaderMemberId], references: [id], onDelete: SetNull)
  viceLeaderMember   Member?          @relation("MinistryViceLeader", fields: [viceLeaderMemberId], references: [id], onDelete: SetNull)
  createdBy          User?            @relation("MinistryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?            @relation("MinistryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  memberMinistries   MemberMinistry[]
  schedules          Schedule[]
  events             Event[]
  announcements      Announcement[]
  financialEntries   FinancialEntry[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([name])
  @@index([displayOrder])
  @@index([isActive])
  @@index([deletedAt])
  @@index([leaderMemberId])
  @@index([viceLeaderMemberId])
}

model MemberMinistry {
  id           String               @id @default(cuid())
  memberId     String
  ministryId   String
  role         MemberMinistryRole   @default(MEMBER)
  status       MemberMinistryStatus @default(ACTIVE)
  entryDate    DateTime
  exitDate     DateTime?
  observations String?
  createdById  String?
  updatedById  String?
  deletedAt    DateTime?
  member       Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  ministry     Ministry             @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  createdBy    User?                @relation("MemberMinistryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?                @relation("MemberMinistryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([memberId])
  @@index([ministryId])
  @@index([status])
  @@index([role])
  @@index([entryDate])
  @@index([exitDate])
  @@index([deletedAt])
  @@index([memberId, ministryId, status, deletedAt])
}

model Schedule {
  id           String           @id @default(cuid())
  title        String
  description  String?
  ministryId   String
  date         DateTime
  startTime    String?
  endTime      String?
  location     String?
  status       ScheduleStatus   @default(DRAFT)
  observations String?
  createdById  String?
  updatedById  String?
  deletedAt    DateTime?
  ministry     Ministry         @relation(fields: [ministryId], references: [id], onDelete: Restrict)
  members      ScheduleMember[]
  songs        ScheduleSong[]
  createdBy    User?            @relation("ScheduleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?            @relation("ScheduleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([title])
  @@index([ministryId])
  @@index([date])
  @@index([status])
  @@index([deletedAt])
}

model ScheduleMember {
  id                 String               @id @default(cuid())
  scheduleId         String
  memberId           String
  role               ScheduleMemberRole   @default(OTHER)
  status             ScheduleMemberStatus @default(PENDING)
  confirmedAt        DateTime?
  declinedAt         DateTime?
  declineReason      String?
  replacedByMemberId String?
  observations       String?
  createdById        String?
  updatedById        String?
  deletedAt          DateTime?
  schedule           Schedule             @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  member             Member               @relation("ScheduleMemberMember", fields: [memberId], references: [id], onDelete: Cascade)
  replacedByMember   Member?              @relation("ScheduleMemberReplacement", fields: [replacedByMemberId], references: [id], onDelete: SetNull)
  createdBy          User?                @relation("ScheduleMemberCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?                @relation("ScheduleMemberUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([scheduleId])
  @@index([memberId])
  @@index([role])
  @@index([status])
  @@index([replacedByMemberId])
  @@index([confirmedAt])
  @@index([declinedAt])
  @@index([deletedAt])
  @@index([scheduleId, memberId, deletedAt])
}

model Song {
  id                    String         @id @default(cuid())
  title                 String
  artist                String?
  youtubeUrl            String?
  referenceKey          String?
  resourceUrl           String?
  simplifiedResourceUrl String?
  notes                 String?
  isActive              Boolean        @default(true)
  createdById           String?
  updatedById           String?
  deletedAt             DateTime?
  createdBy             User?          @relation("SongCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy             User?          @relation("SongUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  scheduleSongs         ScheduleSong[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([title])
  @@index([artist])
  @@index([isActive])
  @@index([deletedAt])
}

model ScheduleSong {
  id                   String    @id @default(cuid())
  scheduleId           String
  songId               String
  position             Int
  referenceKey         String?
  performanceKey       String?
  leadMemberId         String?
  youtubeUrlOverride   String?
  resourceUrlOverride  String?
  useSimplifiedVersion Boolean   @default(false)
  notes                String?
  createdById          String?
  updatedById          String?
  deletedAt            DateTime?
  schedule             Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  song                 Song      @relation(fields: [songId], references: [id], onDelete: Restrict)
  leadMember           Member?   @relation("ScheduleSongLeadMember", fields: [leadMemberId], references: [id], onDelete: SetNull)
  createdBy            User?     @relation("ScheduleSongCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy            User?     @relation("ScheduleSongUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([scheduleId, position, deletedAt])
  @@index([songId])
  @@index([leadMemberId])
  @@index([deletedAt])
}

model UserAccessRequest {
  id               String                  @id @default(cuid())
  name             String
  username         String
  email            String?
  phone            String?
  cpf              String?
  rg               String?
  birthDate        DateTime?
  passwordHash     String
  status           UserAccessRequestStatus @default(PENDING)
  possibleMemberId String?
  approvedMemberId String?
  approvedById     String?
  approvedAt       DateTime?
  rejectedById     String?
  rejectedAt       DateTime?
  rejectionReason  String?
  deletedAt        DateTime?
  possibleMember   Member?                 @relation("UserAccessRequestPossibleMember", fields: [possibleMemberId], references: [id], onDelete: SetNull)
  approvedMember   Member?                 @relation("UserAccessRequestApprovedMember", fields: [approvedMemberId], references: [id], onDelete: SetNull)
  approvedBy       User?                   @relation("UserAccessRequestApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy       User?                   @relation("UserAccessRequestRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([username])
  @@index([email])
  @@index([cpf])
  @@index([rg])
  @@index([phone])
  @@index([status])
  @@index([possibleMemberId])
  @@index([approvedMemberId])
  @@index([approvedById])
  @@index([rejectedById])
  @@index([deletedAt])
  @@index([username, status, deletedAt])
}

model PasswordResetRequest {
  id                   String                     @id @default(cuid())
  identifier           String
  normalizedIdentifier String
  name                 String?
  email                String?
  phone                String?
  cpf                  String?
  status               PasswordResetRequestStatus @default(PENDING)
  userId               String?
  processedById        String?
  requestedAt          DateTime                   @default(now())
  processedAt          DateTime?
  rejectionReason      String?
  deletedAt            DateTime?
  user                 User?                      @relation("PasswordResetRequestUser", fields: [userId], references: [id], onDelete: SetNull)
  processedBy          User?                      @relation("PasswordResetRequestProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@index([identifier])
  @@index([normalizedIdentifier])
  @@index([status])
  @@index([userId])
  @@index([processedById])
  @@index([requestedAt])
  @@index([processedAt])
  @@index([deletedAt])
  @@index([normalizedIdentifier, status, deletedAt])
}

model Announcement {
  id           String               @id @default(cuid())
  title        String
  content      String
  status       AnnouncementStatus   @default(DRAFT)
  audience     AnnouncementAudience @default(ALL)
  ministryId   String?
  isPinned     Boolean              @default(false)
  publishAt    DateTime?
  expiresAt    DateTime?
  externalLink String?
  createdById  String?
  updatedById  String?
  deletedAt    DateTime?
  ministry     Ministry?            @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  createdBy    User?                @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?                @relation("AnnouncementUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  reads        AnnouncementRead[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([title])
  @@index([status])
  @@index([audience])
  @@index([ministryId])
  @@index([isPinned])
  @@index([publishAt])
  @@index([expiresAt])
  @@index([deletedAt])
  @@index([status, audience, publishAt, expiresAt, deletedAt])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@index([userId])
  @@index([readAt])
}

model Event {
  id                   String           @id @default(cuid())
  title                String
  slug                 String           @unique
  description          String?
  type                 EventType        @default(OTHER)
  status               EventStatus      @default(DRAFT)
  ministryId           String?
  responsibleMemberId  String?
  startDate            DateTime
  endDate              DateTime?
  startTime            String?
  endTime              String?
  location             String?
  address              String?
  capacity             Int?
  requiresRegistration Boolean          @default(false)
  isPublic             Boolean          @default(false)
  imageUrl             String?
  observations         String?
  createdById          String?
  updatedById          String?
  deletedAt            DateTime?
  ministry             Ministry?        @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  responsibleMember    Member?          @relation("EventResponsibleMember", fields: [responsibleMemberId], references: [id], onDelete: SetNull)
  financialEntries     FinancialEntry[]
  createdBy            User?            @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy            User?            @relation("EventUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([title])
  @@index([slug])
  @@index([type])
  @@index([status])
  @@index([ministryId])
  @@index([responsibleMemberId])
  @@index([startDate])
  @@index([endDate])
  @@index([isPublic])
  @@index([deletedAt])
}

model FinancialCategory {
  id                 String             @id @default(cuid())
  name               String
  description        String?
  type               FinancialEntryType
  displayOrder       Int                @default(0)
  showInMemberPortal Boolean            @default(false)
  isSystem           Boolean            @default(false)
  isActive           Boolean            @default(true)
  createdById        String?
  updatedById        String?
  deletedAt          DateTime?
  entries            FinancialEntry[]
  createdBy          User?              @relation("FinancialCategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?              @relation("FinancialCategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([name, type])
  @@index([name])
  @@index([type])
  @@index([displayOrder])
  @@index([isActive])
  @@index([showInMemberPortal])
  @@index([deletedAt])
}

model FinancialEntry {
  id            String                 @id @default(cuid())
  entryNumber   Int                    @unique
  type          FinancialEntryType
  memberId      String?
  categoryId    String
  eventId       String?
  ministryId    String?
  amount        Decimal                @db.Decimal(12, 2)
  paymentMethod FinancialPaymentMethod @default(OTHER)
  status        FinancialEntryStatus   @default(CONFIRMED)
  origin        FinancialEntryOrigin   @default(MANUAL)
  anonymous     Boolean                @default(false)
  launchDate    DateTime
  referenceDate DateTime
  observation   String?
  createdById   String?
  updatedById   String?
  deletedAt     DateTime?
  member        Member?                @relation(fields: [memberId], references: [id], onDelete: SetNull)
  category      FinancialCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  event         Event?                 @relation(fields: [eventId], references: [id], onDelete: SetNull)
  ministry      Ministry?              @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  createdBy     User?                  @relation("FinancialEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?                  @relation("FinancialEntryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([entryNumber])
  @@index([type])
  @@index([memberId])
  @@index([categoryId])
  @@index([eventId])
  @@index([ministryId])
  @@index([paymentMethod])
  @@index([status])
  @@index([origin])
  @@index([launchDate])
  @@index([referenceDate])
  @@index([deletedAt])
}

model FinancialClosing {
  id             String    @id @default(cuid())
  date           DateTime  @unique
  openingBalance Decimal   @db.Decimal(12, 2)
  closingBalance Decimal   @db.Decimal(12, 2)
  openedById     String?
  closedById     String?
  observation    String?
  deletedAt      DateTime?
  openedBy       User?     @relation("FinancialClosingOpenedBy", fields: [openedById], references: [id], onDelete: SetNull)
  closedBy       User?     @relation("FinancialClosingClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([date])
  @@index([deletedAt])
}

model Donation {
  id        String       @id @default(cuid())
  amount    Decimal      @db.Decimal(12, 2)
  type      DonationType @default(TITHE)
  donatedAt DateTime     @default(now())
  notes     String?
  memberId  String?
  member    Member?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}
