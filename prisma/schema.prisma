generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  LEADER
  TREASURER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  VISITOR
  TRANSFERRED
  DECEASED
}

enum DonationType {
  TITHE
  OFFERING
  CAMPAIGN
}

enum MemberSex {
  FEMALE
  MALE
  OTHER
  NOT_INFORMED
}

enum WeekDay {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum MinistryIcon {
  MUSIC
  CHILDREN
  CAMERA
  USERS
  HEART
  CROSS
  BOOK
  CHURCH
  MIC
  HOME
}

enum MemberMinistryRole {
  LEADER
  VICE_LEADER
  SECRETARY
  TREASURER
  VOLUNTEER
  MEMBER
}

enum MemberMinistryStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  REMOVED
  LEFT
}

model User {
  id                      String           @id @default(cuid())
  name                    String
  username                String           @unique
  email                   String           @unique
  passwordHash            String
  role                    UserRole         @default(LEADER)
  memberId                String?          @unique
  accessRoleId            String?
  isActive                Boolean          @default(true)
  mustChangePassword      Boolean          @default(false)
  lastLoginAt             DateTime?
  failedLoginAttempts     Int              @default(0)
  lockedUntil             DateTime?
  member                  Member?          @relation("MemberUser", fields: [memberId], references: [id], onDelete: SetNull)
  accessRole              AccessRole?      @relation("UserAccessRole", fields: [accessRoleId], references: [id], onDelete: SetNull)
  createdMembers          Member[]         @relation("MemberCreatedBy")
  updatedMembers          Member[]         @relation("MemberUpdatedBy")
  createdMemberMinistries MemberMinistry[] @relation("MemberMinistryCreatedBy")
  updatedMemberMinistries MemberMinistry[] @relation("MemberMinistryUpdatedBy")
  createdMinistries       Ministry[]       @relation("MinistryCreatedBy")
  updatedMinistries       Ministry[]       @relation("MinistryUpdatedBy")
  createdAccessRoles      AccessRole[]     @relation("AccessRoleCreatedBy")
  updatedAccessRoles      AccessRole[]     @relation("AccessRoleUpdatedBy")
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([accessRoleId])
}

model AccessRole {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  permissions Permission[] @relation("AccessRolePermissions")
  isSystem    Boolean      @default(false)
  isActive    Boolean      @default(true)
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  createdBy   User?        @relation("AccessRoleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?        @relation("AccessRoleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  users       User[]       @relation("UserAccessRole")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([name])
  @@index([isActive])
  @@index([deletedAt])
}

model Permission {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  label       String
  description String?
  module      String
  isSystem    Boolean      @default(true)
  isActive    Boolean      @default(true)
  accessRoles AccessRole[] @relation("AccessRolePermissions")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([code])
  @@index([module])
  @@index([isActive])
}

model Member {
  id                String           @id @default(cuid())
  name              String
  cpf               String?          @unique
  rg                String?
  birthDate         DateTime?
  sex               MemberSex        @default(NOT_INFORMED)
  maritalStatus     String?
  phone             String?
  mobilePhone       String?
  whatsapp          String?
  email             String?          @unique
  zipCode           String?
  street            String?
  number            String?
  complement        String?
  district          String?
  city              String?
  state             String?
  baptismDate       DateTime?
  joinedAt          DateTime?
  status            MemberStatus     @default(ACTIVE)
  notes             String?
  photoUrl          String?
  deletedAt         DateTime?
  createdById       String?
  updatedById       String?
  user              User?            @relation("MemberUser")
  createdBy         User?            @relation("MemberCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?            @relation("MemberUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  ledMinistries     Ministry[]       @relation("MinistryLeader")
  viceLedMinistries Ministry[]       @relation("MinistryViceLeader")
  donations         Donation[]
  memberMinistries  MemberMinistry[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([name])
  @@index([cpf])
  @@index([city])
  @@index([status])
  @@index([deletedAt])
}

model Ministry {
  id                 String           @id @default(cuid())
  name               String           @unique
  slug               String           @unique
  description        String?
  color              String           @default("#2563eb")
  icon               MinistryIcon     @default(USERS)
  imageUrl           String?
  displayOrder       Int              @default(0)
  email              String?
  phone              String?
  meetingDay         WeekDay?
  meetingTime        String?
  location           String?
  notes              String?
  isActive           Boolean          @default(true)
  isSystem           Boolean          @default(false)
  leaderMemberId     String?
  viceLeaderMemberId String?
  createdById        String?
  updatedById        String?
  deletedAt          DateTime?
  leaderMember       Member?          @relation("MinistryLeader", fields: [leaderMemberId], references: [id], onDelete: SetNull)
  viceLeaderMember   Member?          @relation("MinistryViceLeader", fields: [viceLeaderMemberId], references: [id], onDelete: SetNull)
  createdBy          User?            @relation("MinistryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?            @relation("MinistryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  memberMinistries   MemberMinistry[]
  events             Event[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([name])
  @@index([displayOrder])
  @@index([isActive])
  @@index([deletedAt])
  @@index([leaderMemberId])
  @@index([viceLeaderMemberId])
}

model MemberMinistry {
  id           String               @id @default(cuid())
  memberId     String
  ministryId   String
  role         MemberMinistryRole   @default(MEMBER)
  status       MemberMinistryStatus @default(ACTIVE)
  entryDate    DateTime
  exitDate     DateTime?
  observations String?
  createdById  String?
  updatedById  String?
  deletedAt    DateTime?
  member       Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  ministry     Ministry             @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  createdBy    User?                @relation("MemberMinistryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?                @relation("MemberMinistryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([memberId])
  @@index([ministryId])
  @@index([status])
  @@index([role])
  @@index([entryDate])
  @@index([exitDate])
  @@index([deletedAt])
  @@index([memberId, ministryId, status, deletedAt])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  ministryId  String?
  ministry    Ministry? @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Donation {
  id        String       @id @default(cuid())
  amount    Decimal      @db.Decimal(12, 2)
  type      DonationType @default(TITHE)
  donatedAt DateTime     @default(now())
  notes     String?
  memberId  String?
  member    Member?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}
